# Telemetry (Umami) — optional. Leave unset to disable analytics entirely
# (dev and CI are no-ops without these). Copy to `.env.local` to test locally.

# Umami website id for this site (from your Umami dashboard).
VITE_UMAMI_WEBSITE_ID=

# Tracker script URL. Defaults to Umami Cloud if unset.
# Self-host example: https://your-umami-host/script.js
VITE_UMAMI_SRC=https://cloud.umami.is/script.js
